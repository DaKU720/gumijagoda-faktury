# Skopiuj do `.env` i uzupełnij wartości:  cp .env.example .env

# --- Baza danych (PostgreSQL) ---
# Lokalnie: baza z docker-compose. Na hostingu: URL wstrzykiwany przez dostawcę.
DATABASE_URL="postgresql://gumijagoda:gumijagoda@localhost:5432/gumijagoda?schema=public"

# --- KSeF (wyłącznie środowisko testowe) ---
# mock = wbudowane faktury przykładowe (offline, deterministyczne, używane w testach)
# real = prawdziwe API środowiska testowego MF (wymaga KSEF_NIP i KSEF_TOKEN)
KSEF_MODE="mock"
KSEF_BASE_URL="https://api-test.ksef.mf.gov.pl"

# NIP, w którego kontekście uwierzytelniamy się w KSeF (musi być zgodny z tokenem).
KSEF_NIP=""

# Token KSeF wygenerowany w testowej Aplikacji Podatnika (uprawnienie: odczyt faktur).
# SEKRET — trzymany wyłącznie po stronie serwera, nigdy w repo ani we frontendzie.
KSEF_TOKEN=""

# --- Harmonogram automatycznego pobierania (node-cron) ---
# Godziny uruchomień konfiguruje się w UI (Ustawienia → Harmonogram), nie tutaj.
SCHEDULER_ENABLED="true"
TZ="Europe/Warsaw"
